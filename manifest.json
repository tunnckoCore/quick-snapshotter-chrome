{
  "manifest_version": 3,
  "name": "Quick Snapshotter",
  "version": "1.0",
  "description": "Right-click to select and screenshot an element.",
  "permissions": ["contextMenus", "activeTab", "scripting", "downloads", "storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "take-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Start screenshot selection"
    }
  },
  "action": {
    "default_title": "Quick Snapshotter",
    "default_popup": "src/popup.html"
  }
}
